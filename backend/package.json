{
  "name": "mail-app-backend",
  "version": "1.0.0",
  "description": "AI-powered mail application backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:migrate": "node src/db/migrate.js",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mail",
    "ai",
    "gmail",
    "gemini"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.4.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.0",
    "google-auth-library": "^8.9.0",
    "googleapis": "^118.0.0",
    "helmet": "^7.0.0",
    "imapflow": "^1.4.3",
    "jsonwebtoken": "^9.0.0",
    "mailparser": "^3.9.12",
    "nodemailer": "^9.0.1",
    "pg": "^8.10.0",
    "typescript": "^5.0.0",
    "@types/cookie-parser": "^1.4.3",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/express-session": "^1.17.7",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^18.15.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.10.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.59.0",
    "eslint": "^8.40.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node-dev": "^2.0.0"
  }
}
